<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.csc325_firebase_webview_auth.view.RegisterController"
      spacing="14" alignment="CENTER" prefWidth="500" prefHeight="460">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <Label text="Create Account" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

    <VBox spacing="8" maxWidth="320">
        <Label text="Email"/>
        <TextField fx:id="emailField" promptText="you@example.com"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="At least 6 characters"/>

        <Label text="Confirm Password"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Repeat password"/>
    </VBox>

    <Button text="Register" onAction="#onRegister" maxWidth="320" />

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: red;" wrapText="true" maxWidth="320"/>

    <Hyperlink text="Back to Login" onAction="#goToLogin"/>
</VBox>