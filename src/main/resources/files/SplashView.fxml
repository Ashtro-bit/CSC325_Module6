<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17.0.2"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.csc325_firebase_webview_auth.view.SplashController"
           prefWidth="900" prefHeight="600">

    <VBox alignment="CENTER" spacing="16">
        <!-- If you have a logo image, we can set it here -->
        <ImageView fx:id="logoImage" fitWidth="140" fitHeight="140" preserveRatio="true"/>

        <Label text="CSC325 Module 6"
               style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

        <Label text="Loading..."
               style="-fx-font-size: 16px; -fx-opacity: 0.8;"/>
    </VBox>

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>
</StackPane>